generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id                String    @id @default(cuid())
  username          String    @unique  // 用户自定义用户名（推荐但不强制邮箱）
  displayName       String?            // 用户昵称（可后续更改）
  passwordHash      String
  role              String    @default("USER") // USER, ADMIN
  platformKey       String    @unique // 分配给消费者的独立的平台消费 Key
  points            Float     @default(0) // 信用点数
  showOnLeaderboard Boolean   @default(true) // 是否展示在排行榜
  inviteCodeId      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  providedTokens  TokenKey[]
  requestsMade    RequestLog[] @relation("ConsumerLogs")
  invitesCreated  InviteCode[] @relation("Inviter")
  inviteUsed      InviteCode?  @relation(fields: [inviteCodeId], references: [id])
  pointsSent      PointTransfer[] @relation("PointsSent")
  pointsReceived  PointTransfer[] @relation("PointsReceived")
}

model InviteCode {
  id          String   @id @default(cuid())
  code        String   @unique
  maxUses     Int      @default(1)
  usedCount   Int      @default(0)
  creatorId   String
  createdAt   DateTime @default(now())

  creator     User     @relation("Inviter", fields: [creatorId], references: [id])
  users       User[]
}

model TokenKey {
  id              String   @id @default(cuid())
  key             String   @unique // 用户录入的真实的外部官方 Token
  provider        String   @default("openai") // 所属供应商 (e.g. openai)
  status          String   @default("ACTIVE") // 活跃 ACTIVE, 耗尽 EXHAUSTED, 封禁 FROZEN
  isAdminSupply   Boolean  @default(false) // 是否为管理员配置的公共补给廉价 Token
  totalUsedTokens Int      @default(0) // 累计提供消耗的官方 tokens
  usageLimit      Int?     // 使用上限（null 表示无限）
  allowedUsers    String?  // 允许使用的用户名列表（逗号分隔，空=所有人开放）
  userId          String   // 拥有该 Token 的用户
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation(fields: [userId], references: [id])
  requestLogs     RequestLog[]
}

model RequestLog {
  id              String   @id @default(cuid())
  consumerId      String
  tokenId         String
  tokensUsed      Int
  promptTokens    Int      @default(0)
  completionTokens Int     @default(0)
  provider        String?
  model           String?
  inputPricePerM  Float?
  outputPricePerM Float?
  estimatedCostUsd Float?
  consumerPointsDelta Float @default(0)
  providerPointsDelta Float @default(0)
  pricingSourceUrl String?
  pricingRefreshedAt DateTime?
  isDirected      Boolean  @default(false) // 是否定向开放的使用
  status          String   @default("SUCCESS") // 调用状态：SUCCESS, FAILED
  createdAt       DateTime @default(now())

  consumer        User     @relation("ConsumerLogs", fields: [consumerId], references: [id])
  token           TokenKey @relation(fields: [tokenId], references: [id])
}

model PointTransfer {
  id          String   @id @default(cuid())
  fromUserId  String
  toUserId    String
  amount      Float
  createdAt   DateTime @default(now())

  fromUser    User     @relation("PointsSent", fields: [fromUserId], references: [id])
  toUser      User     @relation("PointsReceived", fields: [toUserId], references: [id])
}

model ModelPriceSnapshot {
  id             String   @id @default(cuid())
  provider       String
  model          String
  displayName    String
  inputPricePerM Float
  outputPricePerM Float
  currency       String   @default("USD")
  sourceUrl      String
  fetchedAt      DateTime @default(now())
  isFallback     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@unique([provider, model])
  @@index([provider])
}
